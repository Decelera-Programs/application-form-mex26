{
  "id": "decelera-latam26-application-v1",
  "version": "2.0.0",
  "title": "Aplica a Decelera LATAM 2026",
  "welcomeMessage": "¡Hola! 👋\n\nSoy la asistente de Carlota, nuestra Dealflow Manager. Ahora está sumergida en pitch decks y café ☕, así que me pidió ayudarte con tu aplicación para Decelera LATAM 2026 🌎🚀\n\nSomos un fondo founder-first — ofrecemos hasta $1M en initial funding y una residencia 100% sponsored de 7 días para encontrar nuestras próximas startups.\n\nEsto te tomará unos 11 minutos. Si te equivocas en algo, podrás corregirlo al final.\n\nAl continuar, aceptas que tus datos sean procesados para la evaluación de tu candidatura.",
  "completionMessage": "¡Aplicación enviada! 🚀🎉\n\n¡Gracias por aplicar a Decelera LATAM 2026! 🌎\n\nRevisamos todo personalmente y te avisaremos en máximo 7 días si pasas a la siguiente etapa. Mientras tanto, sigue construyendo 💪\n\nCualquier duda, escríbenos a hola@decelera.com",
  "startStep": "section_about_you",
  "steps": {

    "section_about_you": {
      "id": "section_about_you",
      "type": "statement",
      "question": "¡Empecemos por ti! 👋\n\nUnas preguntas rápidas sobre quién eres y quién está contigo en esto.",
      "nextStep": "founder_first_name"
    },

    "founder_first_name": {
      "id": "founder_first_name",
      "type": "text",
      "question": "¿Cómo te llamas?",
      "placeholder": "Tu nombre",
      "required": true,
      "nextStep": "founder_last_name"
    },

    "founder_last_name": {
      "id": "founder_last_name",
      "type": "text",
      "question": "¿Y tu apellido?",
      "placeholder": "Tu apellido",
      "required": true,
      "nextStep": "founder_email"
    },

    "founder_email": {
      "id": "founder_email",
      "type": "email",
      "question": "¿Cuál es tu email profesional? 📧\n\nPor ahí te contactaremos si avanzas.",
      "placeholder": "tu@startup.com",
      "required": true,
      "nextStep": "founder_linkedin",
      "attioField": "email_addresses",
      "attioObject": "people"
    },

    "founder_linkedin": {
      "id": "founder_linkedin",
      "type": "url",
      "question": "Pásame tu LinkedIn — siempre lo miramos 👀",
      "placeholder": "https://linkedin.com/in/tunombre",
      "required": false,
      "nextStep": "founder_nationality",
      "attioField": "linkedin_1",
      "attioObject": "deals"
    },

    "founder_nationality": {
      "id": "founder_nationality",
      "type": "multiselect",
      "question": "¿De dónde son originalmente los founders del equipo? Marca todos los que apliquen.",
      "required": true,
      "options": [
        "México",
        "Colombia",
        "Chile",
        "Argentina",
        "Perú",
        "Uruguay",
        "Centroamérica & Caribe",
        "USA",
        "Europa",
        "Brasil",
        "Otro"
      ],
      "nextStep": "number_of_founders"
    },

    "number_of_founders": {
      "id": "number_of_founders",
      "type": "select",
      "question": "¿Cuántos founders full-time hay en el equipo?",
      "required": true,
      "options": ["1", "2", "3", "4+"],
      "nextStep": "technical_cofounder",
      "attioField": "number_of_founders",
      "attioObject": "deals"
    },

    "technical_cofounder": {
      "id": "technical_cofounder",
      "type": "boolean",
      "question": "¿Hay un technical founder en el equipo? 🛠️",
      "required": true,
      "nextStep": "equity",
      "attioField": "full_time_cto",
      "attioObject": "deals"
    },

    "equity": {
      "id": "equity",
      "type": "select",
      "question": "¿Qué porcentaje de la empresa está en manos de los founders?",
      "required": true,
      "options": [
        "< 40%",
        "40% - 60%",
        "60% - 80%",
        "> 80%"
      ],
      "nextStep": "section_company",
      "attioField": "equity",
      "attioObject": "deals"
    },

    "section_company": {
      "id": "section_company",
      "type": "statement",
      "question": "¡Cuéntanos de tu startup! 🚀\n\n6 preguntas sobre el setup y el sector.",
      "nextStep": "startup_name"
    },

    "startup_name": {
      "id": "startup_name",
      "type": "text",
      "question": "¿Cómo se llama tu startup?",
      "placeholder": "Nombre de la startup",
      "required": true,
      "nextStep": "startup_website",
      "attioField": "name",
      "attioObject": "companies"
    },

    "startup_website": {
      "id": "startup_website",
      "type": "url",
      "question": "¿Tienen web o dominio? Pásamelo 🌐",
      "placeholder": "https://tustartup.com",
      "required": false,
      "nextStep": "constitution_location",
      "attioField": "domains",
      "attioObject": "companies"
    },

    "constitution_location": {
      "id": "constitution_location",
      "type": "select",
      "question": "¿Dónde está incorporada oficialmente {{startup_name}}?",
      "required": true,
      "options": [
        "LATAM",
        "Spain",
        "U.S.A.",
        "U.K.",
        "E.U.",
        "Portugal",
        "Cayman Islands",
        "Other"
      ],
      "nextStep": "operations_location",
      "attioField": "constitution_company",
      "attioObject": "deals"
    },

    "operations_location": {
      "id": "operations_location",
      "type": "multiselect",
      "question": "¿Y dónde opera {{startup_name}}? Marca todos los mercados donde tienen operación.",
      "required": true,
      "options": [
        "LATAM",
        "U.S.A.",
        "E.U.",
        "Spain",
        "U.K.",
        "France",
        "Italy",
        "Portugal",
        "Other"
      ],
      "nextStep": "constitution_year",
      "attioField": "operations_location",
      "attioObject": "deals"
    },

    "constitution_year": {
      "id": "constitution_year",
      "type": "number",
      "question": "¿En qué año se constituyó {{startup_name}}?",
      "placeholder": "2023",
      "required": true,
      "nextStep": "startup_sector",
      "attioField": "constitution_year",
      "attioObject": "deals"
    },

    "startup_sector": {
      "id": "startup_sector",
      "type": "select",
      "question": "¿En qué sector está {{startup_name}}?",
      "required": true,
      "options": [
        "HealthTech",
        "InsurTech",
        "EdTech",
        "ClimateTech",
        "AgriTech",
        "FoodTech",
        "DeepTech",
        "IndustrialTech",
        "MarketingTech",
        "TransportTech",
        "E-Commerce",
        "Retail",
        "Web3 & Blockchain",
        "AR/VR/XR",
        "SpaceTech",
        "TravelTech",
        "Social Innovation",
        "Circular Economy",
        "Impact & Social Enterprises",
        "Advanced Materials"
      ],
      "nextStep": "business_model",
      "attioField": "sector",
      "attioObject": "deals"
    },

    "business_model": {
      "id": "business_model",
      "type": "select",
      "question": "¿Cuál es el modelo de negocio de {{startup_name}}?",
      "required": true,
      "options": [
        "SaaS",
        "Usage-based",
        "Marketplace",
        "Transaction-based",
        "Licensing",
        "Hardware",
        "Advertising",
        "Enterprise / Contracts",
        "B2B",
        "B2C",
        "Consulting",
        "Other"
      ],
      "nextStep": "section_round",
      "attioField": "business_model",
      "attioObject": "deals"
    },

    "section_round": {
      "id": "section_round",
      "type": "statement",
      "question": "Hablemos de la ronda 💰\n\nSolo 5 datos rápidos para entender dónde están.",
      "nextStep": "raising_amount"
    },

    "raising_amount": {
      "id": "raising_amount",
      "type": "select",
      "question": "¿Cuánto buscan levantar en esta ronda?",
      "required": true,
      "options": [
        "<$500K",
        "$500K-$1M",
        "$1M-$2M",
        ">$2M"
      ],
      "nextStep": "round_stage",
      "attioField": "raise",
      "attioObject": "deals"
    },

    "round_stage": {
      "id": "round_stage",
      "type": "select",
      "question": "¿Qué stage es esta ronda?",
      "required": true,
      "options": [
        "Pre-Seed",
        "Seed",
        "Series A",
        "Otro"
      ],
      "nextStep": "raised_amount",
      "attioField": "stage_round",
      "attioObject": "deals"
    },

    "raised_amount": {
      "id": "raised_amount",
      "type": "select",
      "question": "¿Cuánto han levantado hasta hoy en total (todas las rondas previas)?",
      "required": true,
      "options": [
        "Nada aún",
        "< 500k",
        "500k - 1.5M",
        "1.5M - 2.5M",
        "> 2.5M"
      ],
      "nextStep": "pre_money_valuation",
      "attioField": "raised",
      "attioObject": "deals"
    },

    "pre_money_valuation": {
      "id": "pre_money_valuation",
      "type": "number",
      "question": "¿Cuál es la valoración pre-money que están manejando? (en USD millones, ej. 8 para $8M)",
      "placeholder": "8",
      "required": false,
      "nextStep": "runway",
      "attioField": "pre_money_valuation_7",
      "attioObject": "deals"
    },

    "runway": {
      "id": "runway",
      "type": "select",
      "question": "¿Cuál es su runway actual?",
      "required": true,
      "options": [
        "0 - 2 Months",
        "2 - 5 Months",
        "6 - 12 Months",
        "12+ Months"
      ],
      "nextStep": "section_metrics",
      "attioField": "runway",
      "attioObject": "deals"
    },

    "section_metrics": {
      "id": "section_metrics",
      "type": "statement",
      "question": "Métricas time 📊\n\nVamos con North Star, growth, churn y burn.",
      "nextStep": "north_star"
    },

    "north_star": {
      "id": "north_star",
      "type": "textarea",
      "question": "¿Cuál es su North Star Metric — la que mejor refleja el valor que entregan?",
      "placeholder": "ej. \"$18K MRR\", \"45K MAUs\", \"3.2M transacciones/mes\"",
      "required": true,
      "nextStep": "mom_growth",
      "attioField": "north_star",
      "attioObject": "deals"
    },

    "mom_growth": {
      "id": "mom_growth",
      "type": "select",
      "question": "¿Cuál es su MoM growth promedio del último trimestre?",
      "required": true,
      "options": [
        ">20%",
        "10-20%",
        "5-10%",
        "<5%",
        "NA (building/pivoting)"
      ],
      "nextStep": "net_burn",
      "attioField": "mom_growth",
      "attioObject": "deals"
    },

    "net_burn": {
      "id": "net_burn",
      "type": "select",
      "question": "¿Cuál es su net burn mensual promedio del último trimestre? (USD)",
      "required": true,
      "options": [
        "<10k €",
        "10k-25k €",
        "25k-50k €",
        "50 - 100k €",
        "+100k €"
      ],
      "nextStep": "organic_users",
      "attioField": "net_burn_avg_monthly_4",
      "attioObject": "deals"
    },

    "organic_users": {
      "id": "organic_users",
      "type": "select",
      "question": "¿Qué % de sus usuarios/clientes llegan orgánicamente (sin paid acquisition)?",
      "required": true,
      "options": [
        ">80% come via word-of-mouth, SEO, or organic loops.",
        "50-80% organic, the rest is paid/outbound",
        "<50% organic; we rely heavily on Ads/Sales teams."
      ],
      "nextStep": "churn",
      "attioField": "organic_users",
      "attioObject": "deals"
    },

    "churn": {
      "id": "churn",
      "type": "select",
      "question": "¿Cuál es su monthly churn?",
      "required": true,
      "options": [
        "<2%",
        "2-5%",
        "5-10%",
        ">10%",
        "Not Applicable"
      ],
      "nextStep": "acv",
      "attioField": "churn_avg_last_3_months",
      "attioObject": "deals"
    },

    "acv": {
      "id": "acv",
      "type": "number",
      "question": "¿Cuál es su ACV (Annual Contract Value)? En USD.",
      "placeholder": "12000",
      "required": false,
      "nextStep": "potential_clients",
      "attioField": "acv",
      "attioObject": "deals"
    },

    "potential_clients": {
      "id": "potential_clients",
      "type": "number",
      "question": "¿Cuántos clientes potenciales hay en su TAM?",
      "placeholder": "10000",
      "required": false,
      "nextStep": "section_product",
      "attioField": "potential_clients",
      "attioObject": "deals"
    },

    "section_product": {
      "id": "section_product",
      "type": "statement",
      "question": "El pitch 🧠\n\nEl problema, la solución, el moat y por qué AHORA.\n\nEs el bloque más largo (~3 min) — pero también el que más nos cuenta de ustedes.",
      "nextStep": "problem"
    },

    "problem": {
      "id": "problem",
      "type": "textarea",
      "question": "¿Qué problema están resolviendo?",
      "placeholder": "El problema que resolvemos es...",
      "required": true,
      "maxLength": 280,
      "nextStep": "icp",
      "attioField": "problem",
      "attioObject": "deals"
    },

    "icp": {
      "id": "icp",
      "type": "textarea",
      "question": "¿Quién es su ICP (Ideal Customer Profile)?",
      "placeholder": "Nuestro cliente ideal es...",
      "required": true,
      "maxLength": 280,
      "nextStep": "unique_solution",
      "attioField": "icp",
      "attioObject": "deals"
    },

    "unique_solution": {
      "id": "unique_solution",
      "type": "textarea",
      "question": "¿Qué hace única a su solución vs. lo que ya existe?",
      "placeholder": "Lo que nos diferencia es...",
      "required": true,
      "maxLength": 280,
      "nextStep": "proprietary_data",
      "attioField": "the_secret",
      "attioObject": "deals"
    },

    "proprietary_data": {
      "id": "proprietary_data",
      "type": "textarea",
      "question": "¿Tienen algún dataset propietario o data única? Cuéntanos.",
      "placeholder": "Tenemos datos propietarios de...",
      "required": false,
      "nextStep": "defensibility",
      "attioField": "uniqueness_ip",
      "attioObject": "deals"
    },

    "defensibility": {
      "id": "defensibility",
      "type": "select",
      "question": "¿Cuál es su principal defensibility / moat?",
      "required": false,
      "options": [
        "Data Moat",
        "Deep Integration",
        "Hard Technical Edge",
        "Regulation-Licenses",
        "Network Effects",
        "Brand-GTM",
        "None yet"
      ],
      "nextStep": "third_party_dependance",
      "attioField": "defensibility_4",
      "attioObject": "deals"
    },

    "third_party_dependance": {
      "id": "third_party_dependance",
      "type": "textarea",
      "question": "¿De qué terceros depende su producto? ¿Cómo mitigan ese riesgo?",
      "placeholder": "Dependemos de... y lo mitigamos con...",
      "required": false,
      "nextStep": "compliance",
      "attioField": "third_party_mitigation",
      "attioObject": "deals"
    },

    "compliance": {
      "id": "compliance",
      "type": "select",
      "question": "¿Cómo manejan compliance (GDPR / AI Act / PSD2 / HIPAA…)?",
      "required": true,
      "options": [
        "Formal policies, controls, and processes in place",
        "Informal or partial controls, formalization ongoing",
        "No structured compliance processes yet",
        "Doesn't apply"
      ],
      "nextStep": "tech_stack",
      "attioField": "compliance_7",
      "attioObject": "deals"
    },

    "tech_stack": {
      "id": "tech_stack",
      "type": "textarea",
      "question": "¿Qué tech stack están usando?",
      "placeholder": "ej. Next.js, Python/FastAPI, PostgreSQL en AWS...",
      "required": false,
      "nextStep": "demo_url",
      "attioField": "tech_stack",
      "attioObject": "deals"
    },

    "demo_url": {
      "id": "demo_url",
      "type": "url",
      "question": "Pásame un link al producto / demo 🎬",
      "placeholder": "https://demo.tustartup.com",
      "required": false,
      "nextStep": "deck_url",
      "attioField": "demo",
      "attioObject": "deals"
    },

    "deck_url": {
      "id": "deck_url",
      "type": "url",
      "question": "Y el pitch deck también 📊",
      "placeholder": "https://drive.google.com/...",
      "required": false,
      "nextStep": "why_now_select",
      "attioField": "deck_url",
      "attioObject": "deals"
    },

    "why_now_select": {
      "id": "why_now_select",
      "type": "select",
      "question": "¿Por qué AHORA? ⏰",
      "required": true,
      "options": [
        "Extreme Supply/Demand Imbalance: (e.g., severe labor shortages, energy crisis, or massive infrastructure gaps).",
        "Generative AI / Large Scale Automation: (Enabling a 10x cost reduction or a new capability)",
        "New Mandated Compliance/Reporting: (Companies are now legally forced to buy a solution like yours)",
        "Platform Shift: (e.g. transition from legacy On-Premise to Cloud-native or Hardware to Software-defined)",
        "None / General Market Growth: (Standard organic growth)."
      ],
      "nextStep": "why_now_validation",
      "attioField": "external_tailwind",
      "attioObject": "deals"
    },

    "why_now_validation": {
      "id": "why_now_validation",
      "type": "textarea",
      "question": "Explícanos un poco más el «por qué ahora». Si pueden citar una ley, dato de mercado o cambio tech, mejor.",
      "placeholder": "La ventana de oportunidad se abre porque...",
      "required": true,
      "maxLength": 280,
      "nextStep": "section_closure",
      "attioField": "why_now_validation",
      "attioObject": "deals"
    },

    "section_closure": {
      "id": "section_closure",
      "type": "statement",
      "question": "¡Última parada! 🏁\n\nSolo nos queda saber cómo nos conociste.",
      "nextStep": "how_did_you_find_us"
    },

    "how_did_you_find_us": {
      "id": "how_did_you_find_us",
      "type": "select",
      "question": "¿Cómo nos conociste?",
      "required": true,
      "options": [
        "Referral",
        "Social media (LinkedIn, X, Instagram...)",
        "Google",
        "Event",
        "Press",
        "Decelera Newsletter",
        "Other"
      ],
      "conditions": [
        {
          "if": { "fieldId": "how_did_you_find_us", "operator": "equals", "value": "Referral" },
          "then": "reference_explanation"
        }
      ],
      "nextStep": "network_contact",
      "attioField": "reference_3",
      "attioObject": "deals"
    },

    "reference_explanation": {
      "id": "reference_explanation",
      "type": "text",
      "question": "¿Quién te recomendó? (Nombre y empresa si es posible)",
      "placeholder": "ej. María García de Rappi",
      "required": false,
      "nextStep": "network_contact",
      "attioField": "referral",
      "attioObject": "deals"
    },

    "network_contact": {
      "id": "network_contact",
      "type": "boolean",
      "question": "¿Conoces a alguien del network de Decelera? (mentor, founder del portfolio, LP…)",
      "required": false,
      "conditions": [
        {
          "if": { "fieldId": "network_contact", "operator": "equals", "value": "true" },
          "then": "network_contact_name"
        }
      ],
      "nextStep": "additional_comments"
    },

    "network_contact_name": {
      "id": "network_contact_name",
      "type": "text",
      "question": "¿Quién es y cuál es tu relación con esa persona?",
      "placeholder": "ej. Juan Pérez, mentor del programa 2024",
      "required": false,
      "nextStep": "additional_comments"
    },

    "additional_comments": {
      "id": "additional_comments",
      "type": "textarea",
      "question": "¿Algún comentario adicional que quieras compartir?",
      "placeholder": "Cualquier cosa que consideres relevante...",
      "required": false,
      "nextStep": null
    }

  }
}
